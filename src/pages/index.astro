---
// src/pages/index.astro
import { env as cfEnv } from 'cloudflare:workers';
import Base from '../layouts/Base.astro';
import ArticleCard from '../components/ArticleCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { listPublished } from '../lib/articles';
import type { PublicArticle } from '../lib/types';
const env = cfEnv as unknown as Env;
let articles: PublicArticle[] = [];
try { articles = await listPublished(env, 18); } catch {}
const [lead, ...rest] = articles;
---
<Base title={`${env.SITE_NAME || 'TrustWire Korea'} | 속보와 심층 뉴스`} description="정확하고 빠른 보도를 전하는 디지털 뉴스룸입니다.">
<main class="container hero"><section><p class="eyebrow">Newsroom</p><h1>빠르고 정확한 뉴스를 전합니다</h1><p>주요 소식을 신속하게 전달하고, 오류가 확인되면 즉시 정정합니다.</p><div class="hero-actions"><a class="button" href="/search">뉴스 검색</a><a class="button button--ghost" href="/legal/editorial-policy">편집 원칙</a></div></section><AdSlot format="rail" /></main>
<section class="container section-head"><h2>최신 기사</h2><p>검수 완료된 기사만 게시됩니다.</p></section>
<section class="container grid">{lead ? <ArticleCard article={lead} featured /> : <article class="card featured"><span class="kicker">System</span><h2>게시 대기 중</h2><p>관리자 콘솔에서 기사를 작성하고 검수 후 게시하세요.</p></article>}{rest.map((article) => <ArticleCard article={article} />)}</section>
</Base>
