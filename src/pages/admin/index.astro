---
import Base from '../../layouts/Base.astro';
---
<Base title="Newsroom Admin"><main class="admin"><h1>Newsroom Admin</h1><p>Gemini AI 작성, 수동 기사 등록, SEO 점검, 게시 승인, 알림 관리를 위한 보안 관리자 콘솔입니다.</p><form id="ai"><h2>AI 기사 초안</h2><input name="token" placeholder="ADMIN_TOKEN" required/><input name="topic" placeholder="기사 주제" required/><input name="angle" placeholder="보도 관점(선택)"/><button>Gemini 초안 생성</button></form><form id="seo"><h2>SEO 빠른 점검</h2><input name="title" placeholder="제목"/><input name="description" placeholder="메타 설명"/><textarea name="body" placeholder="본문 HTML"></textarea><button>SEO 점수 확인</button></form><pre id="out"></pre></main><script is:inline>const out=document.querySelector('#out');document.querySelector('#ai')?.addEventListener('submit',async(e)=>{e.preventDefault();const target=e.currentTarget;if(!(target instanceof HTMLFormElement))return;const f=new FormData(target);const r=await fetch('/api/admin/generate',{method:'POST',headers:{authorization:`Bearer ${f.get('token')}`,'content-type':'application/json'},body:JSON.stringify({topic:f.get('topic'),angle:f.get('angle')})});if(out)out.textContent=JSON.stringify(await r.json(),null,2);});document.querySelector('#seo')?.addEventListener('submit',async(e)=>{e.preventDefault();const token=document.querySelector('input[name="token"]')?.value||'';const target=e.currentTarget;if(!(target instanceof HTMLFormElement))return;const f=new FormData(target);const r=await fetch('/api/admin/seo-audit',{method:'POST',headers:{authorization:`Bearer ${token}`,'content-type':'application/json'},body:JSON.stringify(Object.fromEntries(f))});if(out)out.textContent=JSON.stringify(await r.json(),null,2);});</script></Base>
