---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteSchema } from '../lib/seo';
const { title = 'TrustWire Korea', description = '신뢰 중심 디지털 언론사', schema = siteSchema(), noHeader = false } = Astro.props;
---
<html lang="ko">
  <head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title><meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" /><meta name="theme-color" content="#08111f" />
    <link rel="canonical" href={Astro.url.href} /><link rel="alternate" type="application/rss+xml" href="/rss.xml" />
    <meta property="og:title" content={title} /><meta property="og:description" content={description} /><meta property="og:type" content="website" /><meta property="og:locale" content="ko_KR" />
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>{!noHeader && <Header />}<slot /><Footer /></body>
</html>
